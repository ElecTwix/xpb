{
  "name": "@xpb/runtime",
  "version": "0.2.0",
  "description": "XPB runtime library for TypeScript",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hybrid": {
      "types": "./dist/hybrid.d.ts",
      "default": "./dist/hybrid.js"
    },
    "./wasm": {
      "types": "./dist/wasm.d.ts",
      "default": "./dist/wasm.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "xpb",
    "serialization",
    "binary",
    "protobuf",
    "wasm"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
