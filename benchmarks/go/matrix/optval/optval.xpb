package optval

// Optional is the OPTIONAL-HEAVY shape, VAL variant (0.5.0 default: value + a
// Has<Field> bool per optional). Decoding present optionals into the inline
// value fields performs no per-field pointer boxing, so value decode is
// allocation-free.
message Optional {
    1: ?int32 A
    2: ?int64 B
    3: ?string C
    4: ?bool D
    5: ?float64 E
    6: ?uint32 F
    7: ?string G
    8: ?int32 H
}
