package strval

// StrBytes is the STRING/BYTES-HEAVY shape, VAL variant (0.5.0 default:
// zero-copy bytes). Decoded strings (always) and bytes (zero-copy) alias the
// input buffer, so value decode is allocation-free regardless of payload size.
message StrBytes {
    1: string S1
    2: bytes B1
    3: string S2
    4: bytes B2
}
