{
  "name": "@xpb/browser-benchmarks",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "esbuild src/xpb-browser.ts --bundle --outfile=dist/xpb-browser.js --format=esm --target=es2020",
    "build:worker": "esbuild src/xpb-worker.ts --bundle --outfile=dist/xpb-worker.js --format=esm --target=es2020",
    "build:pool": "esbuild src/xpb-worker-pool.ts --bundle --outfile=dist/xpb-worker-pool.js --format=esm --target=es2020",
    "build:bleeding": "esbuild src/xpb-bleeding-edge.ts --bundle --outfile=dist/xpb-bleeding-edge.js --format=esm --target=es2020 && esbuild src/bleeding-edge-worker.ts --bundle --outfile=dist/bleeding-edge-worker.js --format=iife --target=es2020",
    "build:msgpack": "esbuild node_modules/@msgpack/msgpack/dist.esm/index.mjs --bundle --outfile=dist/msgpack.js --format=esm --target=es2020",
    "build:all": "npm run build && npm run build:worker && npm run build:pool && npm run build:bleeding && npm run build:msgpack",
    "bench": "npm run build && npm run build:msgpack && npx tsx src/bench-playwright.ts",
    "bench:bleeding": "npm run build:bleeding && npx tsx src/bench-bleeding-edge.ts"
  },
  "devDependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@types/node": "^24.10.2",
    "esbuild": "^0.20.0",
    "playwright": "^1.40.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "wabt": "^1.0.39"
  }
}
